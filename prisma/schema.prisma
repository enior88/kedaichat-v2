generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  whatsappNumber String?  @unique
  name           String?
  password       String?
  role           String   @default("SELLER")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  stores         Store[]
}

model Store {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  category       String?
  whatsappNumber String
  logoUrl        String?
  paymentQrUrl   String?
  ownerId        String
  isDeliveryEnabled Boolean  @default(false)
  deliveryFee    Float     @default(0)
  archived       Boolean   @default(false)
  isFeatured     Boolean       @default(false)
  aiDescription  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  marketingPosts MarketingPost[]
  groupOrders    GroupOrder[]
  orders         Order[]
  products       Product[]
  resellers      Reseller[]
  owner          User          @relation(fields: [ownerId], references: [id])
  subscription   Subscription?
}

enum ProductType {
  PRODUCT
  SERVICE
}

model Product {
  id          String      @id @default(cuid())
  name        String
  price       Float
  description String?
  category    String?
  imageUrl    String?
  stock       Int?
  active      Boolean     @default(true)
  type        ProductType @default(PRODUCT)
  storeId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  groupOrderItems GroupOrderItem[]
  store       Store       @relation(fields: [storeId], references: [id])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerPhone   String?
  notes           String?
  deliveryType    String      @default("PICKUP")
  deliveryAddress String?
  total           Float
  status          String      @default("PENDING")
  paymentStatus   String      @default("UNPAID")
  paymentProofUrl String?
  storeId         String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  store           Store       @relation(fields: [storeId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  productId String
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])
}

model Reseller {
  id          String       @id @default(cuid())
  name        String
  refCode     String       @unique
  storeId     String
  createdAt   DateTime     @default(now())
  commissions Commission[]
  store       Store        @relation(fields: [storeId], references: [id])
}

model Commission {
  id         String   @id @default(cuid())
  amount     Float
  orderId    String
  resellerId String
  reseller   Reseller @relation(fields: [resellerId], references: [id])
}

model GroupOrder {
  id         String   @id @default(cuid())
  inviteCode String   @unique
  title      String
  deadline   DateTime
  pickupTime String
  status     String   @default("ACTIVE")
  storeId    String
  createdAt  DateTime @default(now())
  store      Store    @relation(fields: [storeId], references: [id])
  items      GroupOrderItem[]
}

model GroupOrderItem {
  id              String      @id @default(cuid())
  participantName String
  quantity        Int
  price           Float
  productId       String
  groupOrderId    String
  createdAt       DateTime    @default(now())
  
  product         Product     @relation(fields: [productId], references: [id])
  groupOrder      GroupOrder  @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                String    @id @default(cuid())
  plan              String    @default("FREE")
  status            String    @default("ACTIVE")
  paymentReceiptUrl String?
  storeId           String    @unique
  expiresAt         DateTime?
  store             Store     @relation(fields: [storeId], references: [id])
}

model PlatformSettings {
  id             String   @id @default("global")
  adminBankQrUrl String?
  updatedAt      DateTime @updatedAt
}

model MarketingPost {
  id          String   @id @default(cuid())
  headline    String
  caption     String
  hashtags    String
  seoTitle    String
  seoDescription String
  storeId     String
  createdAt   DateTime @default(now())
  store       Store    @relation(fields: [storeId], references: [id])
}

model PlatformArticle {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  imageUrl    String?
  category    String   @default("Marketing")
  status      String   @default("DRAFT") // DRAFT, PUBLISHED
  metaPostId  String?  // Reference to FB/IG post ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
